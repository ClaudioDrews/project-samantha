# Project Samantha — Environment Variables

## Required

# OpenRouter API key (for embeddings and LLM extraction)
OPENROUTER_API_KEY=sk-or-...

# Workspace path — directory containing SOUL.md, STATE.md, AGENTS.md, etc.
SAMANTHA_WORKSPACE_PATH=/home/your-user/samantha/workspace

## Qdrant

SAMANTHA_QDRANT_HOST=localhost
SAMANTHA_QDRANT_PORT=6333
SAMANTHA_QDRANT_COLLECTION=agent_memory
SAMANTHA_QDRANT_ARCHIVE_COLLECTION=agent_memory_archive
SAMANTHA_EMBEDDING_MODEL=qwen/qwen3-embedding-8b
SAMANTHA_EMBEDDING_DIM=4096

## Extraction (LLM used for memory extraction)

SAMANTHA_EXTRACTION_MODEL=deepseek/deepseek-v4-flash

## Optional

# Emotional seed words for random retrieval pool
SAMANTHA_EMOTIONAL_SEEDS=sunset, ocean, silence, warmth, distance, home

# Backup path
SAMANTHA_BACKUP_PATH=/home/your-user/samantha/backup

# Logging
LOG_LEVEL=INFO
